# Hardware Profile: low | mid | high
HARDWARE_PROFILE=mid

# Ollama Configuration
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3:8b-q4

# ChromaDB Configuration
CHROMA_PATH=./data/chroma_db

# OSRM Configuration
OSRM_HOST=http://osrm:5000

# Whisper Model Size: tiny | base | small
WHISPER_MODEL=base

# FastEmbed Cache Directory
EMBED_CACHE_DIR=./data/models/embeddings

# Reranker Model Cache
RERANKER_CACHE_DIR=./data/models/reranker

# Whisper Model Download Root
WHISPER_CACHE_DIR=./data/models/whisper

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO