{
  "settings": {
    "minzoom": 0,
    "maxzoom": 14,
    "basezoom": 14,
    "center_lat": 30.0,
    "center_lon": 79.0,
    "initial_zoom": 7
  },
  "layer": {
    "water": {
      "minzoom": 0,
      "maxzoom": 14,
      "filter": ["any", ["==", "natural", "water"], ["==", "waterway", "river"]],
      "simplify_below": 8,
      "simplify_level": 600,
      "buffer-size": 1
    },
    "roads": {
      "minzoom": 5,
      "maxzoom": 14,
      "filter": ["has", "highway"],
      "simplify_below": 10,
      "simplify_level": 500,
      "buffer-size": 2
    },
    "buildings": {
      "minzoom": 12,
      "maxzoom": 14,
      "filter": ["==", "building", "yes"],
      "simplify_below": 14,
      "buffer-size": 0
    },
    "landuse": {
      "minzoom": 0,
      "maxzoom": 14,
      "filter": ["has", "landuse"],
      "simplify_below": 8,
      "simplify_level": 500,
      "buffer-size": 1
    }
  }
}
